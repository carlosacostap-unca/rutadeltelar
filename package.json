{
  "name": "rutadeltelar",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "openspec": "openspec",
    "openspec:list": "openspec list --specs",
    "openspec:validate": "openspec validate --all --no-interactive",
    "video:dev": "remotion studio remotion/index.ts --port=3002",
    "video:render": "node scripts/render-promo-video.mjs",
    "video:screenshots": "node scripts/capture-promo-screenshots.mjs",
    "load:test": "node scripts/load-test.mjs",
    "expo:fixture": "node scripts/create-expo-fixture.mjs --public",
    "expo:prepare": "node scripts/prepare-expo-snapshot.mjs",
    "expo:map:prepare": "node scripts/prepare-expo-map.mjs",
    "expo:package": "node scripts/package-expo.mjs",
    "expo:build": "node scripts/build-expo.mjs",
    "expo:smoke": "node scripts/smoke-expo-package.mjs",
    "expo:electron:icon": "node scripts/create-expo-electron-icon.mjs",
    "expo:electron:package": "node scripts/package-expo-electron.mjs",
    "expo:electron:build": "npm run expo:build && npm run expo:electron:package",
    "expo:electron:smoke": "node scripts/smoke-expo-electron.mjs",
    "expo:verify": "npm run verify && npm run expo:electron:build && npm run test:expo && npm run expo:smoke && npm run expo:electron:smoke",
    "verify": "node scripts/verify.mjs",
    "verify:quick": "node scripts/verify.mjs --skip-playwright",
    "test:unit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/unit/*.test.ts",
    "test:playwright": "playwright test",
    "test:expo": "node scripts/test-expo-package.mjs",
    "test:playwright:ui": "playwright test --ui"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "next": "^16.2.10",
    "pmtiles": "^4.4.1",
    "protomaps-leaflet": "^5.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.3.1",
    "@playwright/test": "^1.59.1",
    "@remotion/cli": "^4.0.486",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "png-to-ico": "^3.0.2",
    "rcedit": "^5.0.2",
    "remotion": "^4.0.486",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
